# ---- required in production ----
# Protects /api/cron/scan. Vercel auto-sends `Authorization: Bearer $CRON_SECRET`
# on cron invocations. Generate one: `openssl rand -hex 32`
CRON_SECRET=

# Set automatically when you connect a Neon Postgres database in the Vercel
# dashboard (Storage -> Create Database -> Neon). One of these will be present.
# DATABASE_URL=
# POSTGRES_URL=

# ---- optional strategy tuning (defaults shown) ----
# CC_MAX_SPEND_USD=100
# CC_MIN_MARGIN=0          # raise to 0.12-0.15 before going live (fee + gas)
# CC_MIN_INSURED_USD=1
# CC_CATEGORIES=Pokemon    # comma-separated, e.g. Pokemon,One Piece
# CC_SOL_USD_FALLBACK=150

# ---- buyer (phase 2) ----
# MASTER SWITCH. Leave false/unset = DRY RUN (logs would-buys, spends nothing).
# Set to true ONLY when you're ready to spend real money.
# CC_BOT_LIVE=false

# Base58 secret key of a FRESH BURNER wallet (Phantom: Export Private Key), or a
# JSON byte array. Set this ONLY in the Vercel env UI — never paste it in chat.
# The wallet's balance IS your total spend cap: fund it with exactly your budget.
# CC_SNIPER_SECRET=
# Solana RPC (Helius/Triton/etc.) used to read balances before each buy.
# CC_SNIPER_RPC_URL=

# buyer gates (defaults shown)
# Pokemon: only buy expensive + really-good-discount cards (we hold plenty).
# CC_POKEMON_MIN_PRICE_USD=100  # skip Pokemon cheaper than this
# CC_POKEMON_MIN_MARGIN=0.15    # Pokemon: require >=15% discount to insured
# CC_MAX_SPEND_USD=350          # listing-query + Pokemon upper price cap
# One Piece: building inventory -> lower floor, kept in burner (see forward cats).
# CC_ONEPIECE_MIN_MARGIN=0.1    # One Piece: flat min discount
# CC_ONEPIECE_MAX_PRICE_USD=200 # One Piece: per-card price ceiling
# CC_CATEGORIES=Pokemon,One Piece   # games scanned/bought
# CC_FORWARD_CATEGORIES=Pokemon     # forwarded to treasury; others kept in burner
# CC_BUY_CURRENCIES=USDC    # only buy listings priced in these
# CC_MAX_BUYS_PER_RUN=1     # at most N buys per minute
# CC_MIN_SOL_RESERVE=0.01   # keep this much SOL for gas
# CC_BUY_TYPES=Card         # only buy these item types (Card = graded singles, no Sealed)
# CC_DEST_WALLET=           # forward bought NFTs here after purchase (empty = keep in burner)

# optional: Discord/Telegram webhook to alert + audit every buy attempt
# CC_ALERT_WEBHOOK=
